{
	"name": "@harperfast/cortex-monorepo",
	"private": true,
	"workspaces": [
		"packages/*"
	],
	"engines": {
		"node": ">=22.0.0"
	},
	"scripts": {
		"test": "vitest run",
		"test:watch": "vitest",
		"format:check": "dprint check",
		"format:fix": "dprint fmt",
		"lint:check": "oxlint packages/",
		"lint:fix": "oxlint packages/ --fix",
		"build": "npm run build --workspaces --if-present",
		"typecheck": "tsc --build packages/cortex-client packages/openclaw-memory packages/cortex-mcp-server",
		"commitlint": "commitlint --edit"
	},
	"devDependencies": {
		"@commitlint/cli": "^20.0.0",
		"@commitlint/config-conventional": "^20.0.0",
		"dprint": "^0.52.0",
		"oxlint": "^1.38.0",
		"typescript": "^5.3.0",
		"vitest": "^4.1.1"
	}
}
