{
  "name": "harper-cortex",
  "version": "0.1.0",
  "description": "Open-source AI memory system powered by Harper Fabric. Clone, configure, deploy.",
  "type": "module",
  "main": "resources.js",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/HarperFast/Harper-Cortex.git"
  },
  "scripts": {
    "start": "harperdb run .",
    "dev": "harperdb dev .",
    "deploy": "npx -y dotenv-cli -- harperdb deploy . restart=rolling replicated=true",
    "test": "node --experimental-test-module-mocks --test test/*.test.js"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "voyageai": "^0.2.1"
  }
}
